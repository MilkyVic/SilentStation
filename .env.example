# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# -----------------------------
# Auth API server (Phase 3)
# -----------------------------

# PostgreSQL connection string used by backend auth service.
# Local example assumes Docker postgres:
# - user: tram_an
# - password: StrongPass123!
# - db: tram_an_db
DATABASE_URL="postgresql://tram_an:StrongPass123%21@localhost:5432/tram_an_db"

# Backend auth server port
AUTH_API_PORT="3001"

# HMAC secret for signing access token (REQUIRED in production)
AUTH_SESSION_SECRET="change-this-secret-in-production"

# Access token lifetime in seconds (default: 8h)
AUTH_ACCESS_TOKEN_TTL_SECONDS="28800"

# Seed test users into PostgreSQL on server start.
# Set "false" in production.
AUTH_SEED_TEST_USERS="true"

# CORS allowed origin for auth API.
# Dev: use "*". Production: set exact frontend domain (e.g. https://app.example.com)
AUTH_API_CORS_ORIGIN="*"

# -----------------------------
# Frontend auth client
# -----------------------------

# Vite dev proxy target for /api/*
AUTH_API_PROXY_TARGET="http://localhost:3001"

# Optional: frontend direct base URL to auth API.
# Leave empty to use relative path (/api) + Vite proxy in local.
VITE_AUTH_API_BASE_URL=""

# Local fallback auth (only recommended in local dev).
# In production, set to "false".
VITE_ENABLE_AUTH_FALLBACK="true"

# -----------------------------
# Email OTP (Gmail SMTP)
# -----------------------------

# OTP time-to-live in seconds (default: 300 = 5 minutes)
AUTH_REGISTER_OTP_TTL_SECONDS="300"

# Max wrong attempts for each OTP session
AUTH_REGISTER_OTP_MAX_ATTEMPTS="5"

# Cooldown between two OTP requests for same username/email (seconds)
AUTH_REGISTER_OTP_RESEND_COOLDOWN_SECONDS="30"

# In dev only: include OTP code in API response for quick testing
AUTH_REGISTER_OTP_EXPOSE_DEV_CODE="true"

# Gmail SMTP credentials (App Password required)
AUTH_GMAIL_SMTP_USER="your-gmail@gmail.com"
AUTH_GMAIL_SMTP_APP_PASSWORD="your-16-char-app-password"

# Optional sender display email, fallback to AUTH_GMAIL_SMTP_USER
AUTH_EMAIL_FROM="your-gmail@gmail.com"
